{
  "name": "win32-privileges",
  "version": "2.0.0",
  "description": "Determine user privileges in Windows",
  "license": "MIT",
  "author": "BadIdeaException",
  "homepage": "https://github.com/BadIdeaException/win32-privileges",
  "repository": {
    "type": "git",
    "url": "https://github.com/BadIdeaException/win32-privileges.git"
  },
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.cts",
  "exports": {
    ".": {
      "require": "./dist/cjs/index.js",
      "import": "./dist/esm/index.js"      
    }
  },
  "os": [
    "win32"
  ],
  "files": [
    "dist"
  ],
  "keywords": [
    "windows",
    "win32",
    "privileges",
    "UAC",
    "root",
    "elevated",
    "admin",
    "administrator"
  ],
  "scripts": {
    "build": "npx rimraf dist && npx tsc -p tsconfig.esm.json && npx tsc -p tsconfig.cjs.json && echo {\"type\": \"commonjs\"} > dist/cjs/package.json",
    "test": "mocha test/**/*.spec.ts",
    "debug-test": "mocha --inspect-wait=0.0.0.0:9229 test/**/*.spec.ts",
    "debug-local-test": "mocha inspect test/**/*.spec.ts"
  },
  "dependencies": {
    "koffi": "^2.15"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/chai": "^5.2.3",
    "@types/node": "^24.12",
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "mocha": {
    "require": [
      "tsx"
    ],
    "recursive": true
  }
}
